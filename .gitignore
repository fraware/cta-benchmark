# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# Lean
/lean/.lake
/lean/build
/lean/lake-packages
**/*.olean

# Python
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp

# Runs and reports (local only)
/runs/*
!/runs/.gitkeep
/reports/*
!/reports/.gitkeep

# Secrets
.env
.env.*
!.env.example

# Build artifacts
/build
/dist
/out
/artifacts/*.zip
/artifacts/_anon_scan/
/artifacts/cta-benchmark-anonymous/
/artifacts/build_anonymous_artifact.log

# `cta validate benchmark --release` writes a timestamped summary; keep v0.2
# tracked when curated, but ignore v0.1 local runs unless explicitly added.
/benchmark/v0.1/manifests/release_summary.json

# Python cache in notebooks folder
/notebooks/.ipynb_checkpoints/
