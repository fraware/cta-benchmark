{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cta-benchmark.org/schemas/experiment.schema.json",
  "title": "ExperimentConfig",
  "description": "Declarative description of a reportable experiment. The runner expands the cartesian product of systems x providers x seeds and materialises one run per combination.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "benchmark_version",
    "split",
    "systems",
    "providers",
    "seeds"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "schema_v1" },
    "experiment_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_v[0-9]+$",
      "description": "Canonical experiment identifier, e.g. pilot_v1."
    },
    "benchmark_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "split": {
      "type": "string",
      "enum": ["dev", "eval", "challenge"]
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*_v[0-9]+$"
      },
      "uniqueItems": true
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true,
      "description": "Workspace-relative paths to provider JSON configs."
    },
    "seeds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 0 },
      "uniqueItems": true
    },
    "generation_parameters": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "temperature": { "type": "number", "minimum": 0.0 },
        "top_p": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "max_tokens": { "type": "integer", "minimum": 1 }
      }
    },
    "annotation_pack": {
      "type": "string",
      "description": "Workspace-relative path to an adjudicated annotation pack to score against. If absent, the runner skips metrics + reports."
    },
    "annotation_human_pack": {
      "type": "string",
      "description": "Optional workspace-relative path to a human-adjudicated pack. When present on disk, annotate plan defaults to this path before annotation_pack."
    },
    "require_full_annotation_coverage": {
      "type": "boolean",
      "description": "If true, release validation requires annotation_pack to cover every (instance_id, system_id) pair in the target split."
    },
    "reports": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "output_subdir": { "type": "string" }
      }
    },
    "notes": { "type": "string" }
  }
}
