{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cta-benchmark.org/schemas/ai_draft_annotation.schema.json",
  "title": "AiDraftAnnotation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_version",
    "instance_id",
    "system_id",
    "annotator_id",
    "source_packet",
    "set_level_scores",
    "critical_unit_coverage",
    "generated_obligations",
    "summary_rationale",
    "recommended_disposition"
  ],
  "properties": {
    "benchmark_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "instance_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*_[0-9]{3}$"
    },
    "system_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_v[0-9]+$"
    },
    "annotator_id": {
      "type": "string",
      "const": "assistant_draft"
    },
    "source_packet": {
      "type": "string",
      "minLength": 1
    },
    "set_level_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_faithfulness",
        "code_consistency",
        "vacuity_rate",
        "proof_utility"
      ],
      "properties": {
        "semantic_faithfulness": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "code_consistency": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "vacuity_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "proof_utility": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "critical_unit_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered", "partial", "missing", "contradicted"],
      "properties": {
        "covered": { "type": "array", "items": { "type": "string", "pattern": "^SU[0-9]+$" }, "uniqueItems": true },
        "partial": { "type": "array", "items": { "type": "string", "pattern": "^SU[0-9]+$" }, "uniqueItems": true },
        "missing": { "type": "array", "items": { "type": "string", "pattern": "^SU[0-9]+$" }, "uniqueItems": true },
        "contradicted": { "type": "array", "items": { "type": "string", "pattern": "^SU[0-9]+$" }, "uniqueItems": true }
      }
    },
    "generated_obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "obligation_index",
          "faithfulness_label",
          "consistency_label",
          "is_vacuous",
          "linked_semantic_units",
          "notes"
        ],
        "properties": {
          "obligation_index": { "type": "integer", "minimum": 0 },
          "faithfulness_label": {
            "type": "string",
            "enum": ["faithful", "partial", "unfaithful", "ambiguous"]
          },
          "consistency_label": {
            "type": "string",
            "enum": ["consistent", "inconsistent", "not_applicable"]
          },
          "is_vacuous": { "type": "boolean" },
          "linked_semantic_units": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SU[0-9]+$" },
            "uniqueItems": true
          },
          "notes": { "type": "string" }
        }
      }
    },
    "summary_rationale": { "type": "string", "minLength": 1 },
    "recommended_disposition": {
      "type": "string",
      "enum": ["usable_as_draft_annotation", "needs_human_review", "discard"]
    }
  }
}
