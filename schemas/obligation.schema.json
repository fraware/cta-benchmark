{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cta-benchmark.org/schemas/obligation.schema.json",
  "title": "ReferenceObligationSet",
  "description": "Gold reference obligations for a benchmark instance.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "instance_id", "benchmark_version", "obligations"],
  "properties": {
    "schema_version": { "type": "string", "const": "schema_v1" },
    "instance_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*_[0-9]{3}$"
    },
    "benchmark_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Obligation" }
    }
  },
  "$defs": {
    "Obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "lean_statement",
        "nl_gloss",
        "linked_semantic_units",
        "importance",
        "proof_relevance"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^obl_[0-9]{3}$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "precondition",
            "postcondition",
            "invariant",
            "termination",
            "bounds",
            "uniqueness",
            "monotonicity",
            "optimality",
            "structural",
            "auxiliary"
          ]
        },
        "lean_statement": {
          "type": "string",
          "minLength": 1,
          "description": "Raw Lean 4 theorem / lemma body (no trailing `:= by sorry`)."
        },
        "nl_gloss": {
          "type": "string",
          "minLength": 1
        },
        "linked_semantic_units": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^SU[0-9]+$"
          }
        },
        "importance": {
          "type": "string",
          "enum": ["critical", "supporting", "optional"]
        },
        "proof_relevance": {
          "type": "string",
          "enum": ["direct", "auxiliary", "none"]
        }
      }
    }
  }
}
