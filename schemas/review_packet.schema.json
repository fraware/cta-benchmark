{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cta-benchmark.org/schemas/review_packet.schema.json",
  "title": "ReviewPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "benchmark_version",
    "instance_id",
    "system_id",
    "domain",
    "difficulty",
    "instance_path",
    "generated_output_path",
    "informal_statement",
    "semantic_units",
    "reference_obligations",
    "generated_obligations",
    "lean_check",
    "behavior_check",
    "context"
  ],
  "properties": {
    "benchmark_version": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+$" },
    "instance_id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*_[0-9]{3}$" },
    "system_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*_v[0-9]+$" },
    "domain": { "type": "string", "minLength": 1 },
    "difficulty": { "type": "string", "minLength": 1 },
    "instance_path": { "type": "string", "minLength": 1 },
    "generated_output_path": { "type": "string", "minLength": 1 },
    "informal_statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "preconditions", "required_properties", "edge_cases"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "preconditions": { "type": "array", "items": { "type": "string" } },
        "required_properties": { "type": "array", "items": { "type": "string" } },
        "edge_cases": { "type": "array", "items": { "type": "string" } }
      }
    },
    "semantic_units": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "reference_obligations": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "generated_obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "kind", "lean_statement", "nl_gloss", "linked_semantic_units", "raw_source"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "kind": { "type": "string" },
          "layer": { "type": "string", "enum": ["benchmark_facing", "auxiliary"] },
          "lean_statement": { "type": "string", "minLength": 1 },
          "nl_gloss": { "type": "string" },
          "linked_semantic_units": { "type": "array", "items": { "type": "string" } },
          "raw_source": { "type": "string", "const": "model" }
        }
      }
    },
    "quality_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "critical_units_covered_by_direct_theorems",
        "critical_units_only_indirectly_covered",
        "off_spec_theorems_present",
        "vacuous_theorems_present"
      ],
      "properties": {
        "critical_units_covered_by_direct_theorems": {
          "type": "array",
          "items": { "type": "string", "pattern": "^SU[0-9]+$" },
          "uniqueItems": true
        },
        "critical_units_only_indirectly_covered": {
          "type": "array",
          "items": { "type": "string", "pattern": "^SU[0-9]+$" },
          "uniqueItems": true
        },
        "off_spec_theorems_present": { "type": "boolean" },
        "vacuous_theorems_present": { "type": "boolean" }
      }
    },
    "lean_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elaborated", "diagnostics_path"],
      "properties": {
        "elaborated": { "type": ["boolean", "null"] },
        "diagnostics_path": { "type": "string", "minLength": 1 }
      }
    },
    "behavior_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_path", "summary"],
      "properties": {
        "report_path": { "type": "string", "minLength": 1 },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["has_counterexample", "counterexample_count"],
          "properties": {
            "has_counterexample": { "type": "boolean" },
            "counterexample_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scaffold_path", "reference_rs_path", "rust_summary_path"],
      "properties": {
        "scaffold_path": { "type": "string", "minLength": 1 },
        "reference_rs_path": { "type": "string", "minLength": 1 },
        "rust_summary_path": { "type": "string", "minLength": 1 }
      }
    }
  }
}
