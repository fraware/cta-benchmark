{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cta-benchmark.org/schemas/harness.schema.json",
  "title": "BehavioralHarness",
  "description": "Per-instance behavioral harness definition for falsification checks.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "harness_type", "seed", "num_trials", "input_generator", "oracle_checks", "timeout_ms"],
  "properties": {
    "schema_version": { "type": "string", "const": "schema_v1" },
    "harness_type": {
      "type": "string",
      "enum": ["exact_output", "property_based", "reference_relational", "edge_case"]
    },
    "seed": { "type": "integer", "minimum": 0 },
    "num_trials": { "type": "integer", "minimum": 1, "maximum": 1000000 },
    "input_generator": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "description": "Named generator recognized by cta_behavior (e.g. 'sorted_int_vec', 'int_vec', 'random_dag')."
        }
      }
    },
    "oracle_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "timeout_ms": { "type": "integer", "minimum": 1, "maximum": 600000 }
  }
}
