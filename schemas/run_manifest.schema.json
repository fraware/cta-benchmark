{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cta-benchmark.org/schemas/run_manifest.schema.json",
  "title": "RunManifest",
  "description": "Reproducibility manifest; required for any paper-reportable run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "repo_commit",
    "benchmark_version",
    "schema_versions",
    "system_id",
    "provider",
    "prompt_template_hash",
    "seed",
    "generation_parameters",
    "toolchains",
    "created_at",
    "runner"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "schema_v1" },
    "run_id": {
      "type": "string",
      "pattern": "^run_[0-9]{4}_[0-9]{2}_[0-9]{2}_[a-z][a-z0-9_]*_[a-z]+_[0-9]{3}$",
      "description": "Canonical: run_YYYY_MM_DD_<system_id>_<split>_<NNN>."
    },
    "repo_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "benchmark_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "schema_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instance", "obligation", "annotation", "generated_output", "results_bundle", "metrics", "rubric"],
      "properties": {
        "instance":         { "type": "string", "pattern": "^schema_v[0-9]+$" },
        "obligation":       { "type": "string", "pattern": "^schema_v[0-9]+$" },
        "annotation":       { "type": "string", "pattern": "^schema_v[0-9]+$" },
        "generated_output": { "type": "string", "pattern": "^schema_v[0-9]+$" },
        "results_bundle":   { "type": "string", "pattern": "^schema_v[0-9]+$" },
        "metrics":          { "type": "string", "pattern": "^metrics_v[0-9]+$" },
        "rubric":           { "type": "string", "pattern": "^rubric_v[0-9]+$" }
      }
    },
    "system_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_v[0-9]+$"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "model", "model_version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "model_version": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string" }
      }
    },
    "prompt_template_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "seed": { "type": "integer", "minimum": 0 },
    "generation_parameters": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "temperature":       { "type": "number", "minimum": 0.0 },
        "top_p":             { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "max_tokens":        { "type": "integer", "minimum": 1 },
        "response_format":   { "type": "string" }
      }
    },
    "toolchains": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rust", "lean"],
      "properties": {
        "rust": { "type": "string", "minLength": 1 },
        "lean": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostname"],
      "properties": {
        "hostname": { "type": "string", "minLength": 1 },
        "runner_id": { "type": "string" },
        "os":       { "type": "string" },
        "arch":     { "type": "string" }
      }
    },
    "cost_reporting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["reported", "unreported_with_reason"]
        },
        "reason_code": {
          "type": "string",
          "description": "Stable machine reason when status is unreported_with_reason."
        },
        "estimated_cost_usd": { "type": "number" }
      }
    }
  }
}
