{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cta-benchmark.org/schemas/semantic_units.schema.json",
  "title": "SemanticUnits",
  "description": "Gold semantic units for an instance. Each unit is an atomic unit of meaning against which obligations are scored.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "instance_id", "benchmark_version", "units"],
  "properties": {
    "schema_version": { "type": "string", "const": "schema_v1" },
    "instance_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*_[0-9]{3}$"
    },
    "benchmark_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/SemanticUnit" }
    }
  },
  "$defs": {
    "SemanticUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "criticality"],
      "properties": {
        "id": { "type": "string", "pattern": "^SU[0-9]+$" },
        "description": { "type": "string", "minLength": 1 },
        "criticality": {
          "type": "string",
          "enum": ["critical", "supporting", "optional"]
        },
        "notes": { "type": "string" },
        "common_failure_modes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
