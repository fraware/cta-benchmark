{
  "name": "openai",
  "model": "gpt-5.4-nano",
  "endpoint": "https://api.openai.com/v1/chat/completions",
  "auth_env": "OPENAI_API_KEY",
  "request_defaults": {
    "temperature": 0.0,
    "max_tokens": 2048,
    "response_format": "json_object"
  },
  "rate_limit": {
    "requests_per_minute": 60,
    "max_concurrent": 4
  }
}
